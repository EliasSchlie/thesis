@misc{hanRubyTeamingImproving2024,
  title = {Ruby {{Teaming}}: {{Improving Quality Diversity Search}} with {{Memory}} for {{Automated Red Teaming}}},
  shorttitle = {Ruby {{Teaming}}},
  author = {Han, Vernon Toh Yan and Bhardwaj, Rishabh and Poria, Soujanya},
  year = 2024,
